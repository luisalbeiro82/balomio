{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "target": "generador",
    "public": ".",
    "headers": [
      {
        "source": "**/*.@(html|js|css|json)",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache" }
        ]
      }
    ],
    "ignore": [
      "firebase.json",
      "**/.*",
      "numeros.JPG",
      "**/node_modules/**"
    ]
  }
}
